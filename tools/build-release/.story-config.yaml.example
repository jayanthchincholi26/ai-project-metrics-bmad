# Copy this file to .story-config.yaml at your repo root, then uncomment and
# edit only what applies to your project. Everything below is optional; an
# absent key always falls back to its documented default — never a fabricated
# behavior. See INSTALL.md for the full explanation of each key.

# Which PM tool kickoff should read from. Default when absent: docs-only.
# source_of_truth: docs-only   # or: jira | confluence

# Which AI coding tool's activity is being captured. Default when absent: claude-code.
# ai_tool: claude-code

# JIRA custom field overrides — only if your site's fields differ from the
# Jira Cloud defaults shown below (only meaningful when source_of_truth: jira):
# jira_points_field: customfield_10016
# jira_sprint_field: customfield_10020

# JIRA transition name overrides — only if your workflow's state names differ from
# the defaults below (checked in order otherwise). Kickoff (Story 6.1) and closing a
# story (Story 6.2) both transition the issue automatically; these only change which
# state name each looks for:
# jira_in_progress_transition: In Progress        # kickoff -> this state (default order: In Progress, In Development, Doing)
# jira_done_transition: Done                      # close -> this state (default order: Done, Closed, Resolved)

# Optional cost tracking — all three are optional and absent by default; without
# them, a snapshot's estimated_cost.usd and token_cost.cost_usd stay null
# (never a fabricated number computed from a missing rate):
# hourly_rate: 10        # USD/hr, used for estimated_cost
# ai_input_rate: 1.25    # USD per 1,000,000 input tokens
# ai_output_rate: 5.00   # USD per 1,000,000 output tokens

# Optional automatic compile/test defect capture (Story 5.4/5.8) — comma-
# separated command-name patterns. A Bash tool call whose command contains
# one of these gets silently rewritten (a harmless exit-code marker appended)
# so its success/failure becomes observable — Claude Code itself doesn't
# expose a command's exit code to hooks, so this project works around that
# rather than relying on a field that doesn't exist. A matched command that
# exits non-zero is logged as a defect automatically; absent by default (no
# defect capture, no command rewriting, without this opt-in). Only the
# matched pattern name is ever recorded — never the full command, its
# output, or stderr.
# test_commands: pytest, npm test
# build_commands: tsc --noEmit, ruff check
